rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Jobs collection: public reads, authenticated creates, owner-only updates/deletes
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.postedBy;
    }

    // Users collection: users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
